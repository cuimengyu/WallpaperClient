<Window x:Class="WallpaperClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WallpaperClient.ViewModels"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="WallpaperOS"
        Width="1480"
        Height="920"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}">

    <Window.Resources>
        <!-- Windows 11 风格资源 -->
        <SolidColorBrush x:Key="TitleBarButtonHoverBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="TitleBarButtonPressedBrush" Color="#D0D0D0"/>
        <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#E81123"/>
        <SolidColorBrush x:Key="CloseButtonPressedBrush" Color="#C50F1F"/>

        <!-- 标题栏图标路径 -->
        <Geometry x:Key="MinimizeIcon">M3 12h18v2H3z</Geometry>
        <Geometry x:Key="MaximizeIcon">M3 3h18v18H3V3zm2 2v14h14V5H5z</Geometry>
        <Geometry x:Key="RestoreIcon">M4 4h12v2H6v10H4V4zm2 2h14v14H6V6zm2 2v10h10V8H8z</Geometry>
        <Geometry x:Key="CloseIcon">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z</Geometry>

        <!-- 标题栏按钮样式 -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextOnDarkBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource TitleBarButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource TitleBarButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource CloseButtonHoverBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource CloseButtonPressedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 侧边栏按钮样式 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextOnDarkSecondaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- 分段按钮样式 -->
        <Style x:Key="SegmentButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 列表项样式 -->
        <Style x:Key="WallpaperListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectedBackgroundBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HoverBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0"
              Background="{StaticResource SidebarBackgroundBrush}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 标题栏左侧：Logo和标题 -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                      Fill="{StaticResource PrimaryBrush}"
                      Stretch="Uniform"
                      Width="16"
                      Height="16"
                      VerticalAlignment="Center"/>
                <TextBlock Margin="8,0,0,0"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextOnDarkBrush}"
                          FontSize="12"
                          FontWeight="SemiBold"
                          Text="WallpaperOS"/>
            </StackPanel>

            <!-- 标题栏中间：搜索框 -->
            <Border Grid.Column="1"
                    Height="24"
                    MaxWidth="400"
                    Margin="20,0"
                    Background="#2D2D2D"
                    CornerRadius="4"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Path Grid.Column="0"
                          Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                          Fill="{StaticResource TextOnDarkSecondaryBrush}"
                          Stretch="Uniform"
                          Width="12"
                          Height="12"
                          Margin="8,0,0,0"
                          VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="{StaticResource TextOnDarkBrush}"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             FontSize="12">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>
            </Border>

            <!-- 标题栏右侧：窗口控制按钮 -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">
                <Button Style="{StaticResource TitleBarButtonStyle}"
                        Click="MinimizeButton_Click">
                    <Path Data="{StaticResource MinimizeIcon}"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Stretch="Uniform"
                          Width="10"
                          Height="1"/>
                    <Button.ToolTip>
                        <ToolTip Content="最小化"/>
                    </Button.ToolTip>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}"
                        Click="MaximizeButton_Click">
                    <Path Data="{StaticResource MaximizeIcon}"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Stretch="Uniform"
                          Width="10"
                          Height="10"/>
                    <Button.ToolTip>
                        <ToolTip Content="最大化"/>
                    </Button.ToolTip>
                </Button>
                <Button Style="{StaticResource CloseButtonStyle}"
                        Click="CloseButton_Click">
                    <Path Data="{StaticResource CloseIcon}"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Stretch="Uniform"
                          Width="10"
                          Height="10"/>
                    <Button.ToolTip>
                        <ToolTip Content="关闭"/>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧边栏 -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackgroundBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8,0,0">
                        <!-- 导航按钮 -->
                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding GetLatestWallpapersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="最新壁纸"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding GetHotWallpapersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="热门壁纸"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding GetRandomWallpapersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="随机壁纸"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 分隔线 -->
                        <Border Height="1"
                                Margin="16,16"
                                Background="#3D3D3D"/>

                        <!-- 功能按钮 -->
                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenLocalWallpapersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 12H4V8h16v10z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="本地壁纸"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenFavoritesCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="我的收藏"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenDownloadsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="下载管理"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 分隔线 -->
                        <Border Height="1"
                                Margin="16,16"
                                Background="#3D3D3D"/>

                        <!-- 设置按钮 -->
                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding OpenSettingsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"/>
                                <TextBlock Text="设置"
                                          Margin="12,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- 状态信息 -->
                        <Border Margin="16,24,16,0"
                                Padding="12"
                                Background="#2D2D2D"
                                CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="状态"
                                          Foreground="{StaticResource TextOnDarkSecondaryBrush}"
                                          FontSize="11"
                                          FontWeight="SemiBold"/>
                                <TextBlock Margin="0,4,0,0"
                                          Text="{Binding StatusMessage}"
                                          Foreground="{StaticResource TextOnDarkBrush}"
                                          FontSize="12"
                                          TextWrapping="Wrap"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="当前页"
                                                  Foreground="{StaticResource TextOnDarkSecondaryBrush}"
                                                  FontSize="10"/>
                                        <TextBlock Margin="0,2,0,0"
                                                  Text="{Binding CurrentPage, StringFormat='第 {0} 页'}"
                                                  Foreground="{StaticResource TextOnDarkBrush}"
                                                  FontSize="12"
                                                  FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="总页数"
                                                  Foreground="{StaticResource TextOnDarkSecondaryBrush}"
                                                  FontSize="10"/>
                                        <TextBlock Margin="0,2,0,0"
                                                  Text="{Binding TotalPages}"
                                                  Foreground="{StaticResource TextOnDarkBrush}"
                                                  FontSize="12"
                                                  FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 壁纸数量 -->
                        <Border Margin="16,8,16,16"
                                Padding="12"
                                Background="#2D2D2D"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                      Fill="{StaticResource PrimaryBrush}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"
                                      VerticalAlignment="Center"/>
                                <TextBlock Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource TextOnDarkBrush}"
                                          FontSize="12"
                                          Text="{Binding Wallpapers.Count, StringFormat='{}{0} 张壁纸'}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右侧主内容区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 顶部操作栏 -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 操作按钮 -->
                        <StackPanel Grid.Column="0"
                                   Orientation="Horizontal">
                            <Button Style="{StaticResource BaseButtonStyle}"
                                   Command="{Binding RefreshCommand}"
                                   Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                          Fill="White"
                                          Stretch="Uniform"
                                          Width="16"
                                          Height="16"
                                          Margin="0,0,8,0"/>
                                    <TextBlock Text="刷新"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                   Command="{Binding PreviousPageCommand}"
                                   Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"
                                          Fill="{StaticResource TextPrimaryBrush}"
                                          Stretch="Uniform"
                                          Width="16"
                                          Height="16"
                                          Margin="0,0,8,0"/>
                                    <TextBlock Text="上一页"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                   Command="{Binding NextPageCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="下一页" Margin="0,0,8,0"/>
                                    <Path Data="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"
                                          Fill="{StaticResource TextPrimaryBrush}"
                                          Stretch="Uniform"
                                          Width="16"
                                          Height="16"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- 壁纸数量显示 -->
                        <Border Grid.Column="2"
                               Padding="16,0"
                               Background="{StaticResource HoverBackgroundBrush}"
                               CornerRadius="4"
                               VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                      Fill="{StaticResource PrimaryBrush}"
                                      Stretch="Uniform"
                                      Width="16"
                                      Height="16"
                                      VerticalAlignment="Center"/>
                                <TextBlock Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          Text="{Binding Wallpapers.Count, StringFormat='{}{0} 张壁纸'}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- 主内容区 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧壁纸列表 -->
                    <Border Grid.Column="0"
                           Background="{StaticResource WindowBackgroundBrush}"
                           BorderBrush="{StaticResource BorderBrush}"
                           BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="16">
                                <TextBlock Text="壁纸列表"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,12"/>

                                <ListBox ItemsSource="{Binding Wallpapers}"
                                        SelectedItem="{Binding SelectedWallpaper, Mode=TwoWay}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemContainerStyle="{StaticResource WallpaperListItemStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Width="60"
                                                       Height="60"
                                                       CornerRadius="4"
                                                       ClipToBounds="True"
                                                       Background="{StaticResource HoverBackgroundBrush}">
                                                    <Image Source="{Binding ThumbnailUrl}"
                                                          Stretch="UniformToFill"/>
                                                </Border>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Id}"
                                                              FontSize="13"
                                                              FontWeight="SemiBold"
                                                              Foreground="{StaticResource TextPrimaryBrush}"
                                                              TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                              Text="{Binding Resolution}"
                                                              FontSize="11"
                                                              Foreground="{StaticResource TextSecondaryBrush}"
                                                              TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- 右侧预览区 -->
                    <ScrollViewer Grid.Column="1"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16">
                            <!-- 大预览卡片 -->
                            <Border Style="{StaticResource CardStyle}"
                                   Padding="0"
                                   Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="400"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 预览图片 -->
                                    <Border Grid.Row="0"
                                           CornerRadius="8,8,0,0"
                                            ClipToBounds="True"
                                            Background="{StaticResource HoverBackgroundBrush}">
                                        <Image Source="{Binding SelectedWallpaper, Converter={StaticResource ImageUrlConverter}}"
                                              Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- 操作区 -->
                                    <Border Grid.Row="1"
                                           Padding="16"
                                           Background="{StaticResource CardBackgroundBrush}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 信息 -->
                                            <StackPanel Grid.Row="0">
                                                <TextBlock Text="{Binding SelectedWallpaper.Id, FallbackValue=请选择一张壁纸}"
                                                          Foreground="{StaticResource TextPrimaryBrush}"
                                                          FontSize="18"
                                                          FontWeight="SemiBold"
                                                          TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Margin="0,8,0,0"
                                                          Text="{Binding SelectedWallpaper.Resolution, FallbackValue=从左侧壁纸列表中选择一张壁纸进行预览}"
                                                          Foreground="{StaticResource TextSecondaryBrush}"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- 操作按钮 -->
                                            <StackPanel Grid.Row="1"
                                                       Orientation="Horizontal"
                                                       Margin="0,16,0,0">
                                                <Button Style="{StaticResource BaseButtonStyle}"
                                                       Command="{Binding SetAsWallpaperCommand}"
                                                       CommandParameter="{Binding SelectedWallpaper}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"
                                                              Fill="White"
                                                              Stretch="Uniform"
                                                              Width="16"
                                                              Height="16"
                                                              Margin="0,0,8,0"/>
                                                        <TextBlock Text="设为壁纸"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                       Command="{Binding DownloadWallpaperCommand}"
                                                       CommandParameter="{Binding SelectedWallpaper}"
                                                       Margin="8,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                                                              Fill="{StaticResource TextPrimaryBrush}"
                                                              Stretch="Uniform"
                                                              Width="16"
                                                              Height="16"
                                                              Margin="0,0,8,0"/>
                                                        <TextBlock Text="保存"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                       Command="{Binding FavoriteWallpaperCommand}"
                                                       CommandParameter="{Binding SelectedWallpaper}"
                                                       Margin="8,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                                              Fill="{StaticResource TextPrimaryBrush}"
                                                              Stretch="Uniform"
                                                              Width="16"
                                                              Height="16"
                                                              Margin="0,0,8,0"/>
                                                        <TextBlock Text="收藏"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                       Command="{Binding DeleteWallpaperCommand}"
                                                       CommandParameter="{Binding SelectedWallpaper}"
                                                       Margin="8,0,0,0"
                                                       Visibility="{Binding IsLocalWallpapersView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                              Fill="#DC3545"
                                                              Stretch="Uniform"
                                                              Width="16"
                                                              Height="16"
                                                              Margin="0,0,8,0"/>
                                                        <TextBlock Text="删除" Foreground="#DC3545"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- 推荐壁纸 -->
                            <TextBlock Text="推荐壁纸"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,12"/>

                            <ItemsControl ItemsSource="{Binding Wallpapers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,8"
                                               Background="{StaticResource CardBackgroundBrush}"
                                               BorderBrush="{StaticResource BorderBrush}"
                                               BorderThickness="1"
                                               CornerRadius="8"
                                               ClipToBounds="True">
                                            <Grid Height="200">
                                                <Grid.InputBindings>
                                                    <MouseBinding Command="{Binding DataContext.SelectWallpaperCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"
                                                                  MouseAction="LeftClick"/>
                                                </Grid.InputBindings>
                                                <Image Source="{Binding ThumbnailUrl}"
                                                      Stretch="UniformToFill"/>

                                                <Border VerticalAlignment="Bottom"
                                                       Background="#CC000000"
                                                       Padding="12,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Id}"
                                                                  FontSize="12"
                                                                  FontWeight="SemiBold"
                                                                  Foreground="White"
                                                                  TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Margin="0,2,0,0"
                                                                  Text="{Binding Resolution}"
                                                                  FontSize="10"
                                                                  Foreground="#B0B0B0"
                                                                  TextTrimming="CharacterEllipsis"/>

                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                            <Button Height="24"
                                                                   Padding="8,0"
                                                                   FontSize="10"
                                                                   Background="#FFFFFF"
                                                                   Foreground="#000000"
                                                                   BorderThickness="0"
                                                                   Margin="0,0,4,0"
                                                                   Command="{Binding DataContext.DownloadWallpaperCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   CommandParameter="{Binding}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                               CornerRadius="3">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="保存"/>
                                                            </Button>

                                                            <Button Height="24"
                                                                   Padding="8,0"
                                                                   FontSize="10"
                                                                   Background="#FFFFFF"
                                                                   Foreground="#000000"
                                                                   BorderThickness="0"
                                                                   Command="{Binding DataContext.SetAsWallpaperCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   CommandParameter="{Binding}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                               CornerRadius="3">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="设为壁纸"/>
                                                            </Button>

                                                            <Button Height="24"
                                                                   Padding="8,0"
                                                                   FontSize="10"
                                                                   Background="#DC3545"
                                                                   Foreground="#FFFFFF"
                                                                   BorderThickness="0"
                                                                   Margin="4,0,0,0"
                                                                   Command="{Binding DataContext.DeleteWallpaperCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   CommandParameter="{Binding}"
                                                                   Visibility="{Binding DataContext.IsLocalWallpapersView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                               CornerRadius="3">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                            VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="删除"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
