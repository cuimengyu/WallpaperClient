<UserControl x:Class="WallpaperClient.Views.DownloadsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- 下载状态颜色转换器 -->
        <Style x:Key="DownloadStateTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Downloading">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Completed">
                    <Setter Property="Foreground" Value="#2196F3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Failed">
                    <Setter Property="Foreground" Value="#F44336"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Paused">
                    <Setter Property="Foreground" Value="#FF9800"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Cancelled">
                    <Setter Property="Foreground" Value="#9E9E9E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Pending">
                    <Setter Property="Foreground" Value="#9E9E9E"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 下载任务卡片样式 -->
        <Style x:Key="DownloadTaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 按钮样式 -->
        <Style x:Key="DownloadActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                               CornerRadius="4"
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题和操作栏 -->
        <Border Grid.Row="0"
               Background="{StaticResource CardBackgroundBrush}"
               BorderBrush="{StaticResource BorderBrush}"
               BorderThickness="0,0,0,1"
               Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                          Fill="{StaticResource PrimaryBrush}"
                          Stretch="Uniform"
                          Width="24"
                          Height="24"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="下载管理"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="20"
                              FontWeight="SemiBold"
                              Margin="12,0,0,0"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="全部暂停"
                           Style="{StaticResource DownloadActionButtonStyle}"
                           Background="#FF9800"
                           Foreground="White"
                           Margin="0,0,8,0"
                           Click="PauseAllButton_Click"/>
                    <Button Content="全部取消"
                           Style="{StaticResource DownloadActionButtonStyle}"
                           Background="#F44336"
                           Foreground="White"
                           Click="CancelAllButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 下载任务列表 -->
        <ScrollViewer Grid.Row="1"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16">
                <!-- 空状态提示 -->
                <Border x:Name="EmptyStateBorder"
                       Visibility="Collapsed"
                       Background="{StaticResource CardBackgroundBrush}"
                       CornerRadius="8"
                       Padding="32"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                              Fill="{StaticResource TextSecondaryBrush}"
                              Stretch="Uniform"
                              Width="64"
                              Height="64"
                              HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无下载任务"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="16"
                                  Margin="0,16,0,0"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="浏览壁纸时点击下载按钮即可开始下载"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="12"
                                  Margin="0,8,0,0"
                                  HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 下载任务列表 -->
                <ItemsControl x:Name="DownloadsList" ItemsSource="{Binding DownloadTasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource DownloadTaskCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 缩略图 -->
                                    <Border Grid.Column="0"
                                           Width="80"
                                           Height="60"
                                           CornerRadius="4"
                                           ClipToBounds="True"
                                           Background="{StaticResource HoverBackgroundBrush}">
                                        <Image Source="{Binding Wallpaper.ThumbnailUrl}"
                                              Stretch="UniformToFill"/>
                                    </Border>

                                    <!-- 任务信息 -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <!-- 壁纸ID和分辨率 -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Wallpaper.Id}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"
                                                      FontSize="14"
                                                      FontWeight="SemiBold"/>
                                            <TextBlock Text=" • "
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      FontSize="12"
                                                      Margin="4,0"/>
                                            <TextBlock Text="{Binding Wallpaper.Resolution}"
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      FontSize="12"/>
                                        </StackPanel>

                                        <!-- 文件名 -->
                                        <TextBlock Text="{Binding FileName}"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  FontSize="11"
                                                  Margin="0,4,0,0"
                                                  TextTrimming="CharacterEllipsis"/>

                                        <!-- 进度条 -->
                                        <Grid Margin="0,8,0,0">
                                            <ProgressBar Height="4"
                                                       Value="{Binding Progress.Progress}"
                                                       Maximum="100"
                                                       Background="{StaticResource HoverBackgroundBrush}"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                        </Grid>

                                        <!-- 下载状态和速度 -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                      Text="{Binding State}"
                                                      Style="{StaticResource DownloadStateTextStyle}"/>

                                            <TextBlock Grid.Column="1"
                                                      Text="{Binding Progress.ProgressText}"
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      FontSize="11"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                      Text="{Binding Progress.SpeedText}"
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      FontSize="11"
                                                      VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- 错误信息 -->
                                        <TextBlock Text="{Binding ErrorMessage}"
                                                  Foreground="#F44336"
                                                  FontSize="11"
                                                  Margin="0,4,0,0"
                                                  TextWrapping="Wrap"
                                                  Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="2"
                                               Orientation="Horizontal"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0">
                                        <!-- 暂停/恢复按钮 -->
                                        <Button Width="32"
                                               Height="32"
                                               Margin="0,0,8,0"
                                               Click="PauseResumeButton_Click"
                                               Tag="{Binding Id}"
                                               Visibility="{Binding State, Converter={StaticResource DownloadStateToVisibilityConverter}, ConverterParameter=CanPause}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource HoverBackgroundBrush}"
                                                           CornerRadius="4">
                                                        <Grid>
                                                            <!-- 暂停图标 -->
                                                            <Path Data="M6 19h4V5H6v14zm8-14v14h4V5h-4z"
                                                                  Fill="{StaticResource TextPrimaryBrush}"
                                                                  Stretch="Uniform"
                                                                  Width="16"
                                                                  Height="16"
                                                                  Visibility="{Binding State, Converter={StaticResource DownloadStateToVisibilityConverter}, ConverterParameter=IsDownloading}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                            <!-- 恢复图标 -->
                                                            <Path Data="M8 5v14l11-7z"
                                                                  Fill="{StaticResource TextPrimaryBrush}"
                                                                  Stretch="Uniform"
                                                                  Width="16"
                                                                  Height="16"
                                                                  Visibility="{Binding State, Converter={StaticResource DownloadStateToVisibilityConverter}, ConverterParameter=IsPaused}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 取消按钮 -->
                                        <Button Width="32"
                                               Height="32"
                                               Margin="0,0,8,0"
                                               Click="CancelButton_Click"
                                               Tag="{Binding Id}"
                                               Visibility="{Binding State, Converter={StaticResource DownloadStateToVisibilityConverter}, ConverterParameter=CanCancel}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource HoverBackgroundBrush}"
                                                           CornerRadius="4">
                                                        <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                              Fill="#F44336"
                                                              Stretch="Uniform"
                                                              Width="16"
                                                              Height="16"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- 删除按钮 -->
                                        <Button Width="32"
                                               Height="32"
                                               Click="RemoveButton_Click"
                                               Tag="{Binding Id}"
                                               Visibility="{Binding State, Converter={StaticResource DownloadStateToVisibilityConverter}, ConverterParameter=CanRemove}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{StaticResource HoverBackgroundBrush}"
                                                           CornerRadius="4">
                                                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                              Fill="#F44336"
                                                              Stretch="Uniform"
                                                              Width="16"
                                                              Height="16"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
